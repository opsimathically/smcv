server {
    listen 443 ssl;
    server_name vault.example.test;
    server_tokens off;

    ssl_protocols TLSv1.3 TLSv1.2;
    add_header Strict-Transport-Security "max-age=31536000" always;

    # The application enforces 8 GiB archive and 8 GiB + 1 MiB multipart
    # limits. Stream protected request/response bodies instead of writing
    # recovery material or revealed values to nginx temporary files.
    client_max_body_size 8193m;
    client_body_timeout 900s;
    send_timeout 930s;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_request_buffering off;
        proxy_buffering off;
        proxy_max_temp_file_size 0;
        proxy_read_timeout 930s;
        proxy_send_timeout 930s;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For "";
        proxy_set_header X-Forwarded-Host "";
        proxy_set_header X-Forwarded-Proto "";
        proxy_set_header X-Real-IP "";
        proxy_set_header Forwarded "";
        proxy_set_header Proxy "";
        proxy_set_header Connection "";
    }

    location = /metrics {
        return 404;
    }
}
