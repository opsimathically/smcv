# SMCV production configuration contains no secret values.
SMCV_ENVIRONMENT=production
SMCV_LISTEN_ADDR=127.0.0.1:8080
SMCV_METRICS_ADDR=127.0.0.1:9090
SMCV_DATA_DIR=/var/lib/smcv
SMCV_KEY_DIR=/var/lib/smcv-key
SMCV_RP_ID=vault.example.test
SMCV_ORIGIN=https://vault.example.test
SMCV_PROTECTED_TRANSPORT=1
SMCV_LOG_FORMAT=json
SMCV_SHUTDOWN_GRACE_SECONDS=15
